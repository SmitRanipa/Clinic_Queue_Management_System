@model List<Clinic_Queue_Management.Models.AppointmentViewModel>
@{
    ViewData["Title"] = "My Appointments";
}

<h3>My Appointments</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Token</th>
            <th>Date</th>
            <th>Time</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.QueueEntry?.TokenNumber</td>
                <td>@a.AppointmentDate</td>
                <td>@a.TimeSlot</td>
                <td>@a.Status</td>
                <td>
                    <a asp-action="AppointmentDetails" asp-route-id="@a.Id" class="btn btn-sm btn-primary">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>